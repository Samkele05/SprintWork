- You must use the EcommerceApi.js file to interact with my store.
- Make sure to preserve the current web app design and visuals.
- Use the provided ProductDetailPage.jsx, ShoppingCart.jsx, ProductsList.jsx, and useCart.jsx template files as the foundation for online store implementation.
- Integrate the CartProvider from useCart.jsx into app's root component to enable cart functionality.
- Implement the ShoppingCart component in main layout/navigation to display the cart sidebar.
- Create a success page to display after successful payment (the initializeCheckout method redirects to successUrl after payment completion).
- Set up proper routing for the ProductDetailPage component (e.g., /product/:id route)
- The ProductList component must be used to display products on main store page or any product listing page.
- After you complete all the things mentioned above, remind me that I can edit the online store (add and edit products, payments, shipping methods) by going back to the Online store drawer.`,uPe="private-hpanel",fn={ar_AR:"ar_AR",zh_CN:"zh_CN",en_GB:"en_GB",fr_FR:"fr_FR",id_ID:"id_ID",lt_LT:"lt_LT",pt_PT:"pt_PT",pt_BR:"pt_BR",es_ES:"es_ES",es_AR:"es_AR",es_CO:"es_CO",es_MX:"es_MX",tr_TR:"tr_TR",uk_UA:"uk_UA",hi_IN:"hi_IN",de_DE:"de_DE",it_IT:"it_IT",nl_NL:"nl_NL",he_IL:"he_IL",pl_PL:"pl_PL",vi_VN:"vi_VN",th_TH:"th_TH",ro_RO:"ro_RO",ja_JP:"ja_JP",ko_KR:"ko_KR",en_PK:"en_PK",en_US:"en_US",en_NG:"en_NG",en_CA:"en_CA",fr_CA:"fr_CA",en_AU:"en_AU",bn_BD:"bn_BD",ar_EG:"ar_EG",ar_MA:"ar_MA",nl_BE:"nl_BE",fr_BE:"fr_BE",de_CH:"de_CH",fr_CH:"fr_CH",de_AT:"de_AT"},cPe="hostinger.com",cf="en_GB",kj={"hostinger.ae":fn.ar_AR,"hostinger.co.uk":fn.en_GB,"hostinger.fr":fn.fr_FR,"hostinger.id":fn.id_ID,"hostinger.lt":fn.lt_LT,"hostinger.pt":fn.pt_PT,"hostinger.com.br":fn.pt_BR,"hostinger.es":fn.es_ES,"hostinger.com.ar":fn.es_AR,"hostinger.co":fn.es_CO,"hostinger.mx":fn.es_MX,"hostinger.com.tr":fn.tr_TR,"hostinger.com.ua":fn.uk_UA,"hostinger.in":fn.en_GB,"hostinger.de":fn.de_DE,"hostinger.it":fn.it_IT,"hostinger.nl":fn.nl_NL,"hostinger.co.il":fn.he_IL,"hostinger.pl":fn.pl_PL,"hostinger.vn":fn.vi_VN,"hostinger.in.th":fn.th_TH,"hostinger.ro":fn.ro_RO,"hostinger.jp":fn.ja_JP,"hostinger.pk":fn.en_PK,"hostinger.com":fn.en_US,"hostinger.ng":fn.en_NG,"hostinger.au":fn.en_AU,"hostinger.ca":fn.en_CA,"hostinger.bd":fn.bn_BD,"hostinger.eg":fn.ar_EG,"hostinger.ma":fn.ar_MA,"hostinger.be":fn.nl_BE,"hostinger.ch":fn.de_CH,"hostinger.at":fn.de_AT},dPe="hostinger.com",fPe="websites-com.hostinger.dev",jY=Object.fromEntries(Object.keys(fn).map(e=>[e,Object.entries(kj).filter(([,t])=>t===fn[e]).map(([t])=>t)])),tln=`
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/svg+xml" href="/vite.svg" />
		<meta name="generator" content="Hostinger Horizons" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Hostinger Horizons</title>
	</head>
	<body>
		<div id="root"></div>
	</body>

{
	"name": "web-app",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview"
	},
	"dependencies": {
		"@radix-ui/react-alert-dialog": "^1.0.5",
