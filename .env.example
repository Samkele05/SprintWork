# ============================================================
# SprintWork Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database (MySQL or TiDB)
DATABASE_URL=mysql://user:password@localhost:3306/sprintwork

# Authentication - JWT secret for session cookies
JWT_SECRET=change-me-to-a-long-random-string

# Server port (default: 3000)
PORT=3000

# OAuth Server (Manus platform)
OAUTH_SERVER_URL=
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=

# AI/LLM API (Manus Forge or OpenAI-compatible)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
